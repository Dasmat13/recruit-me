{
  "name": "recruit-me",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "challenges/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/demo-portfolio",
    "build": "npm run build --workspaces --if-present",
    "preview": "npm run preview --workspace=apps/demo-portfolio",
    "lint": "eslint . --ext .js,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest --watchAll=false"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "typescript": "^5.6.0",
    "eslint": "^9.12.0",
    "@typescript-eslint/parser": "^8.12.0",
    "@typescript-eslint/eslint-plugin": "^8.12.0"
  }
}
